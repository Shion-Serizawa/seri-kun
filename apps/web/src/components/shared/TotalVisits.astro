---
type Props = {
  wrapperClass: string;
  labelClass: string;
  valueClass: string;
};

const { wrapperClass, labelClass, valueClass } = Astro.props;
---

<div class={wrapperClass}>
  <span class={labelClass}>Total Visits:</span>
  <span class={valueClass} data-total-visits-value aria-label="Total visits (not yet loaded)">—</span>
</div>

<script>
  import { updateTotalVisits } from '../../lib/shared/total-visits.client';

  void updateTotalVisits();
</script>
